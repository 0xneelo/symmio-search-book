# symmio-search-book environment template.
# Copy to .secrets/search-book.env and load with:  node --env-file=.secrets/search-book.env scripts/<script>.mjs
# NEVER commit a filled-in copy. The real secret file is git-ignored (.secrets/, .env*).

# --- Corpus build inputs (external Vibe docs export consumed by build-all) ---
# Public docs markdown root and the generated docs-data.json from the Vibe website build.
VIBE_DOCS_PUBLIC=/tmp/vibe_docs/Docs/public
VIBE_DOCS_DATA=/tmp/vibe_docs/Website/public/generated/docs-data.json

# --- Static preview server (serve-static-preview.mjs) ---
SEARCH_BOOK_STATIC_HOST=127.0.0.1
SEARCH_BOOK_STATIC_PORT=8788

# --- Answer-engine service (serve-answer-engine.mjs) ---
SEARCH_BOOK_ANSWER_ENGINE_HOST=127.0.0.1
SEARCH_BOOK_ANSWER_ENGINE_PORT=8787
SEARCH_BOOK_ANSWER_ENGINE_URL=http://127.0.0.1:8787
SEARCH_BOOK_ANSWER_ENGINE_DB=./search-book-answer-engine.sqlite
SEARCH_BOOK_ANSWER_ENGINE_DEFAULT_MODE=extractive
SEARCH_BOOK_ANSWER_ENGINE_RETENTION_DAYS=180
SEARCH_BOOK_ANSWER_ENGINE_ALLOWED_ORIGINS=*
SEARCH_BOOK_ANSWER_ENGINE_RATE_LIMIT_PER_MINUTE=60
SEARCH_BOOK_ANSWER_ENGINE_MAX_BODY_BYTES=65536
SEARCH_BOOK_ANSWER_ENGINE_MAX_RECENT_EVENTS=500

# Moderation export (disabled by default; requires a token when enabled)
SEARCH_BOOK_ANSWER_ENGINE_ENABLE_MODERATION_EXPORT=false
SEARCH_BOOK_ANSWER_ENGINE_MODERATION_TOKEN=
SEARCH_BOOK_ANSWER_ENGINE_MODERATION_LIMIT=200

# Metrics export (disabled by default; requires a token when enabled)
SEARCH_BOOK_ANSWER_ENGINE_ENABLE_METRICS_EXPORT=false
SEARCH_BOOK_ANSWER_ENGINE_METRICS_TOKEN=

# --- LLM RAG answers (run-llm-rag-answer.mjs, live mode only) ---
# Extractive mode needs no key/network. Live mode needs these:
SEARCH_BOOK_LLM_API_KEY=
SEARCH_BOOK_LLM_ENDPOINT=
SEARCH_BOOK_LLM_MODEL=gpt-4.1-mini
SEARCH_BOOK_LLM_API_STYLE=openai-compatible
SEARCH_BOOK_LLM_ALLOW_EXTERNAL_CONTEXT=false

# --- Production preflight overrides (check-production-env.mjs) ---
# Production should use an absolute DB path outside the repo, a concrete HTTPS docs origin,
# LLM default mode, and external context allowed by the operator-approved OpenAI RAG policy.
# Example only; do not paste secrets into committed files.
# SEARCH_BOOK_DEPLOYMENT_SITE_URL=https://docs.example.com
# SEARCH_BOOK_ANSWER_ENGINE_DB=/var/lib/symmio-search-book/search-book-answer-engine.sqlite
# SEARCH_BOOK_ANSWER_ENGINE_ALLOWED_ORIGINS=https://docs.example.com
# SEARCH_BOOK_ANSWER_ENGINE_URL=https://answers.example.com
# SEARCH_BOOK_ANSWER_ENGINE_DEFAULT_MODE=llm
# SEARCH_BOOK_REVIEWER_OWNER=Search Book reviewer rotation
# SEARCH_BOOK_REVIEW_CADENCE=daily
# Used by scripts/backup-answer-engine-db.mjs and the systemd backup timer.
# SEARCH_BOOK_ANSWER_ENGINE_BACKUP_DIR=/var/backups/symmio-search-book
# Latest restore-checked manifest consumed by scripts/check-launch-readiness.mjs.
# SEARCH_BOOK_ANSWER_ENGINE_BACKUP_MANIFEST=/var/backups/symmio-search-book/latest.manifest.json
# SEARCH_BOOK_BACKUP_MAX_AGE_HOURS=24
# SEARCH_BOOK_ANSWER_ENGINE_ENABLE_METRICS_EXPORT=true
# SEARCH_BOOK_ANSWER_ENGINE_METRICS_TOKEN=
# SEARCH_BOOK_LLM_ENDPOINT=https://api.openai.com/v1/chat/completions
# SEARCH_BOOK_LLM_ALLOW_EXTERNAL_CONTEXT=true

# --- Answer reuse cache / embeddings (optional) ---
SEARCH_BOOK_EMBED_ENDPOINT=
SEARCH_BOOK_EMBED_MODEL=
SEARCH_BOOK_REUSE_THRESHOLD=0.92
SEARCH_BOOK_REUSE_MAX_CANDIDATES=20
SEARCH_BOOK_EXAMPLE_LIMIT=6
# Set to 1 to use deterministic local test embeddings instead of a live endpoint.
SEARCH_BOOK_TEST_EMBEDDINGS=

# --- Discord corpus ingestion (parked; optional) ---
SEARCH_BOOK_DISCORD_BOT_TOKEN=
SEARCH_BOOK_DISCORD_CHANNEL_IDS=
SEARCH_BOOK_DISCORD_LAFA_AUTHOR_IDS=
SEARCH_BOOK_DISCORD_MAX_MESSAGES=
SEARCH_BOOK_DISCORD_PUBLICATION_MODE=internal-only
SEARCH_BOOK_DISCORD_STORE_CONTENT=false
